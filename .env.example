# ----------------------------------------
# Local development example
# ----------------------------------------
# Use this file as the source for your local `.env.local`.

NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:8123
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=agent

# Optional server-side LangGraph address for Next.js API routes / server code
LANGGRAPH_API_URL=http://localhost:8123

LOGIN_CENTER_API_URL=https://login-center.example.com

# Local machine PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Alternative PG* configuration
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=postgres
# PGUSER=postgres
# PGPASSWORD=postgres

OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET=your-oss-bucket
OSS_REGION=oss-cn-hangzhou
OSS_ROLE_ARN=acs:ram::xxxx:role/your-role
CDN_HOST=cdn.example.com
